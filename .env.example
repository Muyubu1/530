# Local Postgres connection (dev) — content data (courses/lessons/events) + waitlist fallback.
DATABASE_URL=postgres://user@localhost:5432/refactor530

# Supabase (auth + waitlist). Anon/publishable key is public — safe in the client.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
